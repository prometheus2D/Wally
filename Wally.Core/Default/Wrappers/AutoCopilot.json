{
  "Name": "AutoCopilot",
  "Description": "Agentic — runs gh copilot -i --yolo (can edit files and run tools).",
  "Executable": "gh",
  "ArgumentTemplate": "copilot {model} {sourcePath} --yolo -s -i {prompt}",
  "ModelArgFormat": "--model {model}",
  "SourcePathArgFormat": "--add-dir {sourcePath}",
  "UseSourcePathAsWorkingDirectory": true,
  "CanMakeChanges": true
}
